[
  {
    "id": "tech_001",
    "text": "创新就是区分成功者和失败者的东西。",
    "author": "史蒂夫·乔布斯",
    "source": "斯坦福大学毕业演讲",
    "category": "tech"
  },
  {
    "id": "tech_002",
    "text": "科技本身不算好也不算坏，关键在于你如何使用它。",
    "author": "比尔·盖茨",
    "source": "《未来之路》",
    "category": "tech"
  },
  {
    "id": "tech_003",
    "text": "预测未来的最好方式就是创造未来。",
    "author": "艾伦·凯",
    "source": "Xerox PARC",
    "category": "tech"
  },
  {
    "id": "tech_004",
    "text": "任何足够先进的科技，都与魔法无异。",
    "author": "亚瑟·克拉克",
    "source": "《童年的终结》",
    "category": "tech"
  },
  {
    "id": "tech_005",
    "text": "互联网不代表整个世界，但不互联网的人将只存在于世界的一角。",
    "author": "马云",
    "source": "演讲",
    "category": "tech"
  },
  {
    "id": "tech_006",
    "text": "编程不是关于写代码，而是关于思考。",
    "author": "保罗·格雷厄姆",
    "source": "《黑客与画家》",
    "category": "tech"
  },
  {
    "id": "tech_007",
    "text": "科技最大的意义在于它能赋能于人。",
    "author": "比尔·盖茨",
    "source": "《如何避免一场气候灾难》",
    "category": "tech"
  },
  {
    "id": "tech_008",
    "text": "代码是写给人看的，只是顺便让机器执行。",
    "author": "哈罗德·阿贝尔森",
    "source": "《计算机程序的构造和解释》",
    "category": "tech"
  },
  {
    "id": "tech_009",
    "text": "简单是终极的复杂。",
    "author": "达芬奇（被科技界广泛引用）",
    "source": "设计原则",
    "category": "tech"
  },
  {
    "id": "tech_010",
    "text": "不要怕犯错，但要避免重复犯错。",
    "author": "埃隆·马斯克",
    "source": "《硅谷钢铁侠》",
    "category": "tech"
  },
  {
    "id": "tech_011",
    "text": "技术是工具，不是目的。",
    "author": "凯文·凯利",
    "source": "《必然》",
    "category": "tech"
  },
  {
    "id": "tech_012",
    "text": "优秀的程序员写代码，伟大的程序员抄袭。",
    "author": "史蒂夫·乔布斯",
    "source": "访谈",
    "category": "tech"
  },
  {
    "id": "tech_013",
    "text": "信息革命的意义不在于信息本身，而在于它赋予人们行动的能力。",
    "author": "比尔·盖茨",
    "source": "《未来之路》",
    "category": "tech"
  },
  {
    "id": "tech_014",
    "text": "最好的预测未来的方式就是去发明它。",
    "author": "艾伦·凯",
    "source": "Xerox PARC",
    "category": "tech"
  },
  {
    "id": "tech_015",
    "text": "技术浪潮我们无法阻挡，唯一的选择是学会冲浪。",
    "author": "凯文·凯利",
    "source": "《失控》",
    "category": "tech"
  },
  {
    "id": "tech_016",
    "text": "软件 eats the world.",
    "author": "马克·安德森",
    "source": "访谈",
    "category": "tech"
  },
  {
    "id": "tech_017",
    "text": "代码即文档，文档即代码。",
    "author": "马丁·福勒",
    "source": "《重构》",
    "category": "tech"
  },
  {
    "id": "tech_018",
    "text": "技术只是手段，人文才是目的。",
    "author": "乔布斯",
    "source": "斯坦福大学毕业演讲",
    "category": "tech"
  },
  {
    "id": "tech_019",
    "text": "创新来自跨界融合。",
    "author": "史蒂夫·约翰逊",
    "source": "《创新者的基因》",
    "category": "tech"
  },
  {
    "id": "tech_020",
    "text": "技术应该为人服务，而不是让人为技术服务。",
    "author": "佚名",
    "source": "科技哲学",
    "category": "tech"
  }
]
