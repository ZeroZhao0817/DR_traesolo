[
  {
    "id": "wp_001",
    "text": "管理就是把复杂的问题简单化，把混乱的事情规范化。",
    "author": "杰克·韦尔奇",
    "source": "《赢》",
    "category": "workplace"
  },
  {
    "id": "wp_002",
    "text": "正确的战略依赖于正确的认识。",
    "author": "稻盛和夫",
    "source": "《活法》",
    "category": "workplace"
  },
  {
    "id": "wp_003",
    "text": "成功不是终点，失败也不是末日，最重要的是继续前进的勇气。",
    "author": "丘吉尔",
    "source": "演讲",
    "category": "workplace"
  },
  {
    "id": "wp_004",
    "text": "效率是把事情做对，效果是做对的事情。",
    "author": "彼得·德鲁克",
    "source": "《管理的实践》",
    "category": "workplace"
  },
  {
    "id": "wp_005",
    "text": "没有执行力的战略只是空想。",
    "author": "拉姆·查兰",
    "source": "《执行》",
    "category": "workplace"
  },
  {
    "id": "wp_006",
    "text": "一个人永远成不了大事，一群人才能成就梦想。",
    "author": "佚名",
    "source": "管理语录",
    "category": "workplace"
  },
  {
    "id": "wp_007",
    "text": "不要为失败找理由，要为成功找方法。",
    "author": "佚名",
    "source": "职场励志",
    "category": "workplace"
  },
  {
    "id": "wp_008",
    "text": "工作不是谋生的手段，而是服务的机会。",
    "author": "亨利·福特",
    "source": "《我的生活与工作》",
    "category": "workplace"
  },
  {
    "id": "wp_009",
    "text": "细节决定成败，态度决定一切。",
    "author": "佚名",
    "source": "管理格言",
    "category": "workplace"
  },
  {
    "id": "wp_010",
    "text": "先做正确的事，再把事做正确。",
    "author": "彼得·德鲁克",
    "source": "《有效的管理者》",
    "category": "workplace"
  },
  {
    "id": "wp_011",
    "text": "你的价值不取决于你拥有什么，而取决于你付出什么。",
    "author": "佚名",
    "source": "职场智慧",
    "category": "workplace"
  },
  {
    "id": "wp_012",
    "text": "优秀的团队不是选出来的，是练出来的。",
    "author": "佚名",
    "source": "管理语录",
    "category": "workplace"
  },
  {
    "id": "wp_013",
    "text": "机会总是留给有准备的人。",
    "author": "路易斯·巴斯德",
    "source": "演讲",
    "category": "workplace"
  },
  {
    "id": "wp_014",
    "text": "沟通是管理的基石。",
    "author": "佚名",
    "source": "管理学",
    "category": "workplace"
  },
  {
    "id": "wp_015",
    "text": "不要害怕犯错误，但要害怕重复犯同样的错误。",
    "author": "佚名",
    "source": "职场建议",
    "category": "workplace"
  },
  {
    "id": "wp_016",
    "text": "领导者的任务不是去取悦人们，而是带领人们走向正确的方向。",
    "author": "约翰·马克斯韦尔",
    "source": "《领导力的5个层次》",
    "category": "workplace"
  },
  {
    "id": "wp_017",
    "text": "时间是最宝贵的资源，如何运用时间，决定了一个人的价值。",
    "author": "佚名",
    "source": "时间管理",
    "category": "workplace"
  },
  {
    "id": "wp_018",
    "text": "成功的人找方法，失败的人找借口。",
    "author": "佚名",
    "source": "励志语录",
    "category": "workplace"
  },
  {
    "id": "wp_019",
    "text": "管理的本质是激发人的善意和潜能。",
    "author": "张瑞敏",
    "source": "《进行管理》",
    "category": "workplace"
  },
  {
    "id": "wp_020",
    "text": "没有完美的个人，只有完美的团队。",
    "author": "佚名",
    "source": "团队管理",
    "category": "workplace"
  }
]
